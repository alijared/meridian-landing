---
/**
 * Waitlist CTA that keeps Meridian's own button styling and opens the Tally
 * form in a popup overlay (Tally's officially-supported embed mode).
 *
 * The button carries `data-tally-open` + layout attributes; Tally's embed.js
 * reads these and opens the real form in a modal/slide-over, which handles its
 * own session + submission. No reverse-engineered POST, nothing to break.
 */
const FORM_ID = "aQl4Wq";
---

<div class="mx-auto w-full max-w-md">
  <button
    type="button"
    data-tally-open={FORM_ID}
    data-tally-layout="modal"
    data-tally-width="540"
    data-tally-hide-title="1"
    data-tally-overlay="1"
    data-tally-emoji-text="👋"
    data-tally-emoji-animation="wave"
    class="group inline-flex h-12 w-full items-center justify-center gap-2 rounded-lg bg-accent px-7 text-sm font-semibold text-on-accent shadow-[0_8px_30px_rgba(201,168,106,0.25)] transition-all hover:bg-accent-2 hover:shadow-[0_8px_40px_rgba(201,168,106,0.4)] sm:w-auto sm:px-10"
  >
    Join the waitlist
    <svg
      class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
      viewBox="0 0 20 20"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        fill-rule="evenodd"
        d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z"
        clip-rule="evenodd"></path>
    </svg>
  </button>

  <p class="mt-4 text-xs text-ink-3">
    No spam. We&rsquo;ll only email you about your beta access.
  </p>
</div>

<!--
  Load Tally's embed.js once. It auto-binds every [data-tally-open] element on
  the page. The guard re-runs the binder if the script is already present.
-->
<script>
  const TALLY_SRC = "https://tally.so/widgets/embed.js";

  function initTallyPopup() {
    const w = window as unknown as { Tally?: unknown };
    if (typeof w.Tally !== "undefined") return; // already loaded & bound

    const existing = document.querySelector<HTMLScriptElement>(
      `script[src="${TALLY_SRC}"]`,
    );
    if (existing) return; // loading in flight; embed.js binds on load

    const s = document.createElement("script");
    s.src = TALLY_SRC;
    document.body.appendChild(s);
  }

  initTallyPopup();
</script>
