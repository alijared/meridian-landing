---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.tsx";
import Hero from "../components/Hero.tsx";
import ProblemCards from "../components/ProblemCards.tsx";
import Features from "../components/Features.tsx";
import HowItWorks from "../components/HowItWorks.tsx";
import PricingCards from "../components/PricingCards.tsx";
import TallyPopup from "../components/TallyPopup.astro";
import Reveal from "../components/Reveal.tsx";

const marqueeItems = [
  "Follow top investors",
  "3,200+ strategies shared",
  "Public performance rankings",
  "Investing communities",
  "Transparent track records",
  "Copy with one click",
  "Creator leaderboards",
];
---

<Layout>
  <span id="top"></span>
  <Navbar client:load />

  <main>
    <!-- ============================ 1 · HERO ============================ -->
    <section class="relative overflow-hidden pt-36 pb-20 sm:pt-44 sm:pb-28">
      <!-- animated background layers -->
      <div class="gradient-mesh" aria-hidden="true"></div>
      <div class="hero-grid" aria-hidden="true"></div>
      <!-- bottom fade into page -->
      <div
        class="pointer-events-none absolute inset-x-0 bottom-0 z-0 h-40 bg-gradient-to-b from-transparent to-bg"
        aria-hidden="true"
      >
      </div>

      <Hero client:load />
    </section>

    <!-- ====================== 2 · SOCIAL PROOF BAR ====================== -->
    <section class="relative border-y border-rule bg-paper/40 py-5">
      <div class="marquee relative overflow-hidden">
        <!-- edge fades -->
        <div
          class="pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-gradient-to-r from-bg to-transparent"
          aria-hidden="true"
        >
        </div>
        <div
          class="pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-gradient-to-l from-bg to-transparent"
          aria-hidden="true"
        >
        </div>

        <div class="marquee-track">
          {
            /* duplicate the set twice so the -50% loop is seamless */
            [0, 1].map(() => (
              <div class="flex shrink-0 items-center">
                {marqueeItems.map((item) => (
                  <div class="flex items-center">
                    <span class="px-6 text-sm font-medium tracking-wide text-ink-2 whitespace-nowrap">
                      {item}
                    </span>
                    <span class="text-accent/50" aria-hidden="true">
                      ·
                    </span>
                  </div>
                ))}
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ================= 3 · DIFFERENTIATOR CALLOUT ==================== -->
    <section class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
      <Reveal client:visible>
        <div class="mx-auto max-w-2xl text-center">
          <p
            class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-accent"
          >
            The difference
          </p>
          <h2
            class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl"
          >
            Strategies are social objects, not private tools
          </h2>
          <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-ink-2 sm:text-lg">
            On Meridian, strategies are shared, ranked, and discussed openly.
            Follow creators, join communities, and see live leaderboards of the
            best-performing strategies in real time. The best strategies spread
            through the network, and anyone can copy, remix, or improve them.
          </p>
        </div>
      </Reveal>
    </section>

    <!-- ===================== 3.5 · PROBLEM / GAP ======================= -->
    <section class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
      <Reveal client:visible>
        <div class="mx-auto max-w-2xl text-center">
          <h2
            class="font-serif text-3xl font-semibold leading-tight tracking-tight text-ink sm:text-4xl"
          >
            The best strategies<br class="hidden sm:block" /> stay hidden.
          </h2>
        </div>
      </Reveal>

      <div class="mt-14">
        <ProblemCards client:visible />
      </div>
    </section>

    <!-- ======================== 4 · FEATURES =========================== -->
    <section id="features" class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
      <Reveal client:visible>
        <div class="mx-auto max-w-2xl text-center">
          <p
            class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-accent"
          >
            The social layer
          </p>
          <h2
            class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl"
          >
            A social network built for investing
          </h2>
        </div>
      </Reveal>

      <div class="mt-14">
        <Features client:visible />
      </div>
    </section>

    <!-- ======================== 4.5 · CREATORS ========================= -->
    <section class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
      <Reveal client:visible>
        <div class="mx-auto max-w-2xl text-center">
          <p
            class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-accent"
          >
            For creators
          </p>
          <h2
            class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl"
          >
            Build a following through performance
          </h2>
          <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-ink-2 sm:text-lg">
            Publish strategies, build a reputation, and gain followers. On
            Meridian, your track record speaks for itself. Investing knowledge
            becomes a social asset, and creators build reputation and influence
            through performance.
          </p>
        </div>
      </Reveal>

      <div class="mx-auto mt-12 grid max-w-4xl gap-5 sm:grid-cols-3">
        <Reveal client:visible>
          <div class="glass-soft rounded-2xl p-6">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-accent/20 text-xs font-bold text-accent">NO</div>
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-ink">Naomi Okafor</p>
                <p class="text-xs text-ink-3">3.1k followers</p>
              </div>
            </div>
            <div class="mt-4 flex items-baseline justify-between">
              <p class="font-mono text-2xl font-semibold text-gain">+47.2%</p>
              <span class="rounded-full bg-warn-soft px-2 py-0.5 text-[10px] font-semibold uppercase text-warn">med risk</span>
            </div>
            <p class="mt-1 text-xs text-ink-3">Adaptive Momentum · 5d return</p>
          </div>
        </Reveal>
        <Reveal client:visible delay={0.1}>
          <div class="glass-soft rounded-2xl p-6">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-signal/20 text-xs font-bold text-signal">DR</div>
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-ink">Daniel Reyes</p>
                <p class="text-xs text-ink-3">2.4k followers</p>
              </div>
            </div>
            <div class="mt-4 flex items-baseline justify-between">
              <p class="font-mono text-2xl font-semibold text-gain">+34.6%</p>
              <span class="rounded-full bg-loss-soft px-2 py-0.5 text-[10px] font-semibold uppercase text-loss">high risk</span>
            </div>
            <p class="mt-1 text-xs text-ink-3">Volatility Harvest · 30d return</p>
          </div>
        </Reveal>
        <Reveal client:visible delay={0.2}>
          <div class="glass-soft rounded-2xl p-6">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gain/20 text-xs font-bold text-gain">PA</div>
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-ink">Priya Anand</p>
                <p class="text-xs text-ink-3">1.7k followers</p>
              </div>
            </div>
            <div class="mt-4 flex items-baseline justify-between">
              <p class="font-mono text-2xl font-semibold text-gain">+21.8%</p>
              <span class="rounded-full bg-warn-soft px-2 py-0.5 text-[10px] font-semibold uppercase text-warn">med risk</span>
            </div>
            <p class="mt-1 text-xs text-ink-3">Sector Rotation · 30d return</p>
          </div>
        </Reveal>
      </div>
    </section>

    <!-- =================== 4.75 · TRUST & TRANSPARENCY ================= -->
    <section class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
      <Reveal client:visible>
        <div class="mx-auto max-w-2xl text-center">
          <p
            class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-accent"
          >
            Trust
          </p>
          <h2
            class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl"
          >
            Performance is public
          </h2>
          <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-ink-2 sm:text-lg">
            Every strategy is evaluated using transparent performance data.
            Review returns, risk metrics, drawdowns, consistency, and community
            adoption before deciding to follow or copy a strategy.
          </p>
        </div>
      </Reveal>

      <div class="mx-auto mt-12 grid max-w-3xl gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {["Verified performance history", "Risk-adjusted metrics", "Public creator leaderboards", "Transparent strategy rankings", "Follower and adoption counts", "No self-reported returns"].map((item) => (
          <Reveal client:visible>
            <div class="glass-soft flex items-center gap-3 rounded-xl px-5 py-4">
              <svg class="h-5 w-5 shrink-0 text-gain" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm font-medium text-ink-2">{item}</span>
            </div>
          </Reveal>
        ))}
      </div>
    </section>

    <!-- ====================== 5 · HOW IT WORKS ========================= -->
    <section
      id="how-it-works"
      class="relative mx-auto max-w-6xl px-6 py-24 sm:py-32"
    >
      <Reveal client:visible>
        <div class="mx-auto max-w-2xl text-center">
          <p
            class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-accent"
          >
            How it works
          </p>
          <h2
            class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl"
          >
            From discovery to execution
          </h2>
        </div>
      </Reveal>

      <div class="mt-16">
        <HowItWorks client:visible />
      </div>
    </section>

    <!-- ========================= 6 · PRICING =========================== -->
    <section id="pricing" class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
      <Reveal client:visible>
        <div class="mx-auto max-w-2xl text-center">
          <p
            class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-accent"
          >
            Pricing
          </p>
          <h2
            class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl"
          >
            The network is free. Power tools are not.
          </h2>
          <p class="mt-4 text-base leading-relaxed text-ink-2">
            Full access to social features, strategy discovery, and paper trading. Always free.
            Upgrade to Pro for live trading, advanced analytics, and unlimited experimentation.
          </p>
        </div>
      </Reveal>

      <div class="mt-14">
        <PricingCards client:visible />
      </div>
    </section>

    <!-- ====================== 7 · WAITLIST CTA ========================= -->
    <section id="waitlist" class="relative overflow-hidden px-6 py-28 sm:py-36">
      <!-- strong visual weight: gradient glow backdrop -->
      <div class="gradient-mesh opacity-80" aria-hidden="true"></div>
      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-b from-bg via-transparent to-bg"
        aria-hidden="true"
      >
      </div>

      <div class="relative z-10 mx-auto max-w-2xl text-center">
        <Reveal client:visible>
          <h2
            class="font-serif text-4xl font-semibold tracking-tight text-ink sm:text-5xl"
          >
            Invest alongside the <span class="text-gradient-gold">best.</span>
          </h2>
          <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-ink-2 sm:text-lg">
            Meridian is the social network where investing strategies are shared,
            ranked, discovered, and executed in one place. Join the waitlist for
            early access.
          </p>
        </Reveal>

        <div class="mt-10">
          <TallyPopup />
        </div>
      </div>
    </section>

    <!-- ========================== 8 · FOOTER =========================== -->
    <footer class="border-t border-rule bg-paper/30">
      <div class="mx-auto max-w-6xl px-6 py-14">
        <div
          class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between"
        >
          <div>
            <a
              href="#top"
              class="flex items-center gap-2 font-serif text-xl font-semibold text-accent"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 22 22"
                class="h-6 w-6"
              >
                <circle
                  cx="11"
                  cy="11"
                  r="10"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"></circle>
                <path d="M1 11 L 21 11" stroke="currentColor" stroke-width="1.6"
                ></path>
                <path
                  d="M5 6.5 Q 11 11 5 15.5"
                  stroke="currentColor"
                  stroke-width="1.6"
                  fill="none"></path>
              </svg>
              Meridian
            </a>
            <p class="mt-3 text-sm text-ink-2">The social network for investing strategies.</p>
          </div>

          <nav class="flex flex-col gap-3 sm:flex-row sm:gap-8" aria-label="Legal">
            <a
              href="/privacy"
              class="text-sm text-ink-2 transition-colors hover:text-ink"
              >Privacy Policy</a
            >
            <a
              href="/terms"
              class="text-sm text-ink-2 transition-colors hover:text-ink"
              >Terms of Use</a
            >
          </nav>
        </div>

        <div
          class="mt-12 border-t border-rule pt-8 text-center text-xs text-ink-3 md:text-left"
        >
          © 2026 Meridian. All rights reserved.
        </div>
      </div>
    </footer>
  </main>
</Layout>

<script>
  // Smooth-scroll same-page anchor links without writing the #hash to the URL,
  // so the address bar stays clean (e.g. stays "/" instead of "/#features").
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const link = target.closest<HTMLAnchorElement>('a[href^="#"]');
    if (!link) return;

    const id = link.getAttribute("href")?.slice(1);
    if (!id) return;

    const section = document.getElementById(id);
    if (!section) return;

    e.preventDefault();
    section.scrollIntoView({ behavior: "smooth", block: "start" });
    // keep the URL clean — no trailing #anchor
    history.replaceState(null, "", window.location.pathname + window.location.search);
  });
</script>
