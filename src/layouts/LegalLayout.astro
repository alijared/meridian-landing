---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  /** human-readable last-updated date, e.g. "June 2026" */
  updated?: string;
}

const { title, updated } = Astro.props;
---

<Layout title={`${title} — Meridian`}>
  <div class="min-h-screen">
    <!-- minimal header -->
    <header class="border-b border-rule">
      <div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
        <a
          href="/"
          class="flex items-center gap-2 font-serif text-xl font-semibold text-accent"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 22 22" class="h-6 w-6">
            <circle cx="11" cy="11" r="10" fill="none" stroke="currentColor" stroke-width="1.6"></circle>
            <path d="M1 11 L 21 11" stroke="currentColor" stroke-width="1.6"></path>
            <path d="M5 6.5 Q 11 11 5 15.5" stroke="currentColor" stroke-width="1.6" fill="none"></path>
          </svg>
          Meridian
        </a>
        <a
          href="/"
          class="text-sm font-medium text-ink-2 transition-colors hover:text-ink"
        >
          ← Back to home
        </a>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-6 py-16 sm:py-24">
      <h1 class="font-serif text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
        {title}
      </h1>
      {
        updated && (
          <p class="mt-3 text-sm text-ink-3">Last updated: {updated}</p>
        )
      }

      <div class="mt-10 text-sm leading-relaxed text-ink-2">
        <slot />
      </div>
    </main>

    <footer class="border-t border-rule">
      <div class="mx-auto max-w-3xl px-6 py-8 text-xs text-ink-3">
        © 2026 Meridian. All rights reserved.
      </div>
    </footer>
  </div>
</Layout>
